-- ====== ВКЛАДКА SILENT AIM (С FOV КРУГОМ) ======
local silentSection = silentTab:Section("Silent Aim Settings")
silentSection:Paragraph("Info", "Shoots through walls without moving your aim!", 0)
silentSection:Paragraph("Target", "Always aims at the HEAD | Ignores teammates", 1)

silentSection:Toggle("Enable Silent Aim", state.aimbot.silentAim, function(val)
    state.aimbot.silentAim = val
    if val then
        checkWeapons()
        if not mainMaid._silentTask then
            mainMaid._silentTask = RunService.RenderStepped:Connect(function()
                if not state.enabled or not state.aimbot.silentAim then return end
                silentTarget = getSilentAimTarget()
                updateFovCircle()
            end)
        end
        print("[Silent Aim] Enabled")
    else
        if mainMaid._silentTask then
            mainMaid._silentTask:Disconnect()
            mainMaid._silentTask = nil
        end
        silentTarget = nil
        if fovCircle then fovCircle.Visible = false end
        print("[Silent Aim] Disabled")
    end
end, 2)

silentSection:Slider("Silent FOV", 50, 500, state.aimbot.silentFov, 10, function(val)
    state.aimbot.silentFov = val
    updateFovCircle()
    print("Silent FOV:", val)
end, 3)

silentSection:Toggle("Show FOV Circle", state.aimbot.showFovCircle, function(val)
    state.aimbot.showFovCircle = val
    if val then
        if not fovCircle then
            createFovCircle()
        end
        updateFovCircle()
    else
        if fovCircle then
            fovCircle.Visible = false
        end
    end
    print("FOV Circle:", val and "ON" or "OFF")
end, 4)

