    state.enabled = val
    if not val then
        for _, esp in pairs(espObjects) do
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Health.Visible = false
            for _, bone in pairs(esp.Skeleton) do
                if bone then bone.Visible = false end
            end
        end
    end
end, 1)

mainSection:Toggle("Unlock Mouse", state.mouseUnlock, function(val)
    state.mouseUnlock = val
    toggleMouseUnlock(val)
end, 2)

mainSection:Paragraph("Status", "Script is " .. (state.enabled and "Active" or "Inactive"), 3)

-- Вкладка AIMBOT
local aimSection = aimTab:Section("Aimbot Settings")
aimSection:Paragraph("Info", "Aimbot works ALWAYS | Only alive targets", 0)
aimSection:Paragraph("Target", "Always aims at the HEAD | Ignores teammates", 1)

aimSection:Toggle("Enable Aimbot", state.aimbot.enabled, function(val)
    state.aimbot.enabled = val
    if val then
        if not mainMaid._aimbotTask then
            mainMaid._aimbotTask = RunService.RenderStepped:Connect(aimbotLoop)
            print("[Aimbot] Enabled")
        end
    else
        if mainMaid._aimbotTask then
            mainMaid._aimbotTask:Disconnect()
            mainMaid._aimbotTask = nil
            print("[Aimbot] Disabled")
        end
    end
end, 2)

aimSection:Slider("FOV", 50, 500, state.aimbot.fov, 10, function(val)
    state.aimbot.fov = val
end, 3)

aimSection:Slider("Smoothness", 0.1, 0.9, state.aimbot.smoothness, 0.05, function(val)
    state.aimbot.smoothness = val
end, 4)

-- Вкладка SILENT AIM
local silentSection = silentTab:Section("Silent Aim Settings")
silentSection:Paragraph("Info", "Bullets fly to enemies within the radius", 0)
silentSection:Paragraph("Target", "Always aims at the HEAD | Ignores teammates", 1)

silentSection:Toggle("Enable Silent Aim", state.silentAim.enabled, function(val)
    state.silentAim.enabled = val
    if val then
        checkWeapons()
        if not mainMaid._silentTask then
            mainMaid._silentTask = RunService.RenderStepped:Connect(function()
                if not state.enabled or not state.silentAim.enabled then return end
                silentTarget = getSilentAimTarget()
                updateFovCircle()
            end)
        end
        print("[Silent Aim] Enabled - Bullets fly to targets in radius!")
    else
        if mainMaid._silentTask then
            mainMaid._silentTask:Disconnect()
            mainMaid._silentTask = nil
        end
        silentTarget = nil
        if fovCircle then fovCircle.Visible = false end
        print("[Silent Aim] Disabled")
    end
end, 2)

silentSection:Slider("Silent FOV", 50, 500, state.silentAim.fov, 10, function(val)
    state.silentAim.fov = val
    updateFovCircle()
    print("Silent FOV:", val)
end, 3)

silentSection:Toggle("Show FOV Circle", state.silentAim.showCircle, function(val)
    state.silentAim.showCircle = val
    if val then
        if not fovCircle then createFovCircle() end
        updateFovCircle()
    else
        if fovCircle then fovCircle.Visible = false end
    end
    print("FOV Circle:", val and "ON" or "OFF")
end, 4)

silentSection:Toggle("Team Check", state.silentAim.teamCheck, function(val)
    state.silentAim.teamCheck = val
    print("Team check:", val and "ON" or "OFF")
end, 5)

silentSection:Paragraph("How it works", 
    "1. Finds nearest ALIVE enemy in FOV\n" ..
    "2. Intercepts your shots\n" ..
    "3. Redirects bullets to HEAD\n" ..
    "4. Works through walls!\n" ..
    "5. Your aim stays still\n" ..
    "6. NO aim movement!", 6)

-- Вкладка TELEPORTS
local teleSection = teleTab:Section("Teleport Settings")
teleSection:Toggle("Enable Teleports", state.teleport.enabled, function(val)
    state.teleport.enabled = val
end, 1)
teleSection:Dropdown("Teleport Mode", {"Front", "Behind", "Random"}, state.teleport.mode, function(val)
    state.teleport.mode = val
end, 2)
teleSection:Keybind("Teleport Key", state.teleport.key, function(key)
    state.teleport.key = key
end, 3)
teleSection:Slider("Teleport Distance", 10, 200, state.teleport.distance, 5, function(val)
    state.teleport.distance = val
end, 4)

-- Вкладка ESP
local espSection = espTab:Section("ESP Settings")
espSection:Paragraph("Info", "Shows players through walls | Hides when dead", 0)

espSection:Toggle("Enable ESP", state.esp.enabled, function(val)
    state.esp.enabled = val
    if val then
        if not mainMaid._espTask then
            mainMaid._espTask = RunService.RenderStepped:Connect(updateESP)
        end
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then createESPObject(player) end
        end
    else
        if mainMaid._espTask then
            mainMaid._espTask:Disconnect()
            mainMaid._espTask = nil
        end
        for _, esp in pairs(espObjects) do
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Health.Visible = false
            for _, bone in pairs(esp.Skeleton) do
                if bone then bone.Visible = false end
            end
        end
    end
end, 1)

espSection:Toggle("Boxes", state.esp.boxes, function(val)
    state.esp.boxes = val
end, 2)
espSection:Toggle("Names", state.esp.names, function(val)
    state.esp.names = val
end, 3)
espSection:Toggle("Skeleton", state.esp.skeleton, function(val)
    state.esp.skeleton = val
    if not val then
        for _, esp in pairs(espObjects) do
            for _, bone in pairs(esp.Skeleton) do
                if bone then bone.Visible = false end
            end
        end
    end
end, 4)
espSection:Toggle("Health Bar", state.esp.healthBar, function(val)
    state.esp.healthBar = val
end, 5)
espSection:Slider("Distance", 50, 5000, state.esp.distance, 5, function(val)
    state.esp.distance = val
end, 6)
espSection:ColorPicker("ESP Color", state.esp.color, function(color)
    state.esp.color = color
    for _, esp in pairs(espObjects) do
        esp.Box.Color = color
        for _, bone in pairs(esp.Skeleton) do
            if bone then bone.Color = color end
        end
    end
end, 7)

-- Вкладка НАСТРОЕК
local settingsSection = settingsTab:Section("UI Settings")
settingsSection:Slider("Menu Transparency", 0, 1, state.transparency, 0.05, function(val)
    state.transparency = val
    updateTransparency()
end, 1)
settingsSection:Slider("Blur Size", 0, 24, state.blurSize, 1, function(val)
    state.blurSize = val
    window.BlurSize = val
end, 2)

settingsSection:Keybind("Toggle Menu Key", state.binds.toggleMenu, function(key)
    if key then
        state.binds.toggleMenu = key
        window.ToggleKey = key
        print("[Settings] Menu key changed to:", key.Name)
    end
end, 3)
settingsSection:Keybind("Unlock Mouse Key", state.binds.unlockMouse, function(key)
    if key then
        state.binds.unlockMouse = key
        print("[Settings] Unlock mouse key changed to:", key.Name)
    end
end, 4)
settingsSection:Keybind("Disable All Key", state.binds.disableAll, function(key)
    if key then
        state.binds.disableAll = key
        print("[Settings] Disable all key changed to:", key.Name)
    end
end, 5)

settingsSection:Paragraph("Current Binds", 
    "Menu: " .. tostring(state.binds.toggleMenu.Name) .. "\n" ..
    "Unlock Mouse: " .. tostring(state.binds.unlockMouse.Name) .. "\n" ..
    "Disable All: " .. tostring(state.binds.disableAll.Name), 6)

-- ====== ОБРАБОТКА КЛАВИШ ======
mainMaid:Give(UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == state.binds.unlockMouse then
        state.mouseUnlock = not state.mouseUnlock
        toggleMouseUnlock(state.mouseUnlock)
    end
    
    if state.enabled and state.teleport.enabled and input.KeyCode == state.teleport.key then
        local target = getSilentAimTarget()
        if target and not isTeamMate(target) and isPlayerAlive(target) then
            teleportToPlayer(target)
            print("[Teleport] Teleported to", target.Name)
        end
    end
    
    if input.KeyCode == state.binds.disableAll then
        print("[DISABLE] Disabling ALL features...")
        state.enabled = false
        state.aimbot.enabled = false
        if mainMaid._aimbotTask then
            mainMaid._aimbotTask:Disconnect()
            mainMaid._aimbotTask = nil
        end
        
        state.silentAim.enabled = false
        if mainMaid._silentTask then
            mainMaid._silentTask:Disconnect()
            mainMaid._silentTask = nil
        end
        silentTarget = nil
        if fovCircle then fovCircle.Visible = false end
        
        state.esp.enabled = false
        if mainMaid._espTask then
            mainMaid._espTask:Disconnect()
            mainMaid._espTask = nil
        end
        for _, esp in pairs(espObjects) do
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Health.Visible = false
            for _, bone in pairs(esp.Skeleton) do
                if bone then bone.Visible = false end
            end
        end
        
        state.teleport.enabled = false
        if state.mouseUnlock then
            state.mouseUnlock = false
            toggleMouseUnlock(false)
        end
        print("[DISABLE] ALL features disabled!")
    end
end))

-- ====== ОТСЛЕЖИВАНИЕ ======
mainMaid:Give(Players.PlayerAdded:Connect(function(player)
    if state.esp.enabled then
        task.wait(0.5)
        createESPObject(player)
    end
end))

mainMaid:Give(LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if state.silentAim.enabled then
        checkWeapons()
    end
end))

mainMaid:Give(RunService.RenderStepped:Connect(function()
    if state.enabled and state.silentAim.enabled then
        checkWeapons()
        updateFovCircle()
    end
end))

-- ====== КОНФИГИ ======
window:CreateConfigSection(mainTab, "Configs")

-- ====== ОЧИСТКА ======
window:OnDestroy(function()
    toggleMouseUnlock(false)
    if fovCircle then
        pcall(function() fovCircle:Remove() end)
        fovCircle = nil
    end
    for _, esp in pairs(espObjects) do
        pcall(function()
            if esp.Box then esp.Box:Remove() end
            if esp.Name then esp.Name:Remove() end
            if esp.Health then esp.Health:Remove() end
            for _, bone in pairs(esp.Skeleton) do
                if bone then bone:Remove() end
            end
        end)
    end
    espObjects = {}
    hookedWeapons = {}
    mainMaid:Cleanup()
    print("Leek Cheats unloaded successfully!")
end)

-- ====== ПРИМЕНЯЕМ НАЧАЛЬНЫЕ НАСТРОЙКИ ======
updateTransparency()
window.BlurSize = state.blurSize
createFovCircle()

-- ====== ИНФОРМАЦИЯ ======
print("====================================")
print("Leek Cheats loaded successfully!")
print("by Witoshik")
print("====================================")
print("Press " .. tostring(state.binds.toggleMenu.Name) .. " to toggle GUI")
print("AIMBOT: Works ALWAYS | Only alive targets")
print("SILENT AIM: Bullets fly to ALIVE enemies in radius")
print("  - NO aim movement!")
print("  - Show FOV Circle: Show range circle")
print("TELEPORT: Press T to teleport (alive enemies only)")
print("ESP: Shows players through walls | Hides when dead")
print("DISABLE ALL: Press " .. tostring(state.binds.disableAll.Name))
print("====================================")

return window
