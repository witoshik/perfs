-- ====== ФУНКЦИЯ ОБНОВЛЕНИЯ ПРОЗРАЧНОСТИ ======
local function updateTransparency()
    if window and window.Gui then
        window.Gui.BackgroundTransparency = state.transparency
        window.BackdropTransparency = state.transparency
    end
end

-- ====== РАЗБЛОКИРОВКА МЫШИ ======
local function toggleMouseUnlock(unlock)
    if unlock then
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
        GuiService.MouseIconEnabled = true
        print("[Mouse] UNLOCKED")
    else
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = false
        GuiService.MouseIconEnabled = false
        print("[Mouse] LOCKED")
    end
end

-- ====== FOV КРУГ ======
local function createFovCircle()
    if not hasDrawing then return end
    if fovCircle then
        pcall(function() fovCircle:Remove() end)
        fovCircle = nil
    end
    
    fovCircle = Drawing.new("Circle")
    fovCircle.Visible = false
    fovCircle.Radius = state.silentAim.fov
    fovCircle.Color = Color3.fromRGB(200, 200, 255)
    fovCircle.Thickness = 1.5
    fovCircle.Filled = false
    fovCircle.NumSides = 64
    fovCircle.Transparency = 0.3
    return fovCircle
end

local function updateFovCircle()
    if not fovCircle then
        fovCircle = createFovCircle()
    end
    if not fovCircle then return end
    
    if state.silentAim.showCircle and state.silentAim.enabled then
        local viewport = Camera.ViewportSize
        fovCircle.Visible = true
        fovCircle.Position = Vector2.new(viewport.X/2, viewport.Y/2)
        fovCircle.Radius = state.silentAim.fov
    else
        fovCircle.Visible = false
    end
end

-- ====== ПРОВЕРКА: ЖИВ ЛИ ИГРОК ======
local function isPlayerAlive(player)
    if not player then return false end
    local character = player.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    
    if humanoid.Health <= 0 then return false end
    
    local state = humanoid:GetState()
    if state == Enum.HumanoidStateType.Dead then return false end
    
    return true
end

-- ====== ПРОВЕРКА КОМАНДЫ ======
local function isTeamMate(player)
    if not state.silentAim.teamCheck then return false end
    local localTeam = LocalPlayer.Team
    if not localTeam then return false end
    return localTeam == player.Team
end

-- ====== ПОЛУЧЕНИЕ ПОЗИЦИИ ГОЛОВЫ ======
local function getTargetPart(player)
    local character = player.Character
    if not character then return nil end
    local part = character:FindFirstChild("Head")
    if not part then
        part = character:FindFirstChild("HumanoidRootPart")
    end
    return part
end

-- ====== ПОЛУЧЕНИЕ ЖИВЫХ ИГРОКОВ ======
local function getPlayers()
    local players = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if isTeamMate(player) then continue end
        if not isPlayerAlive(player) then continue end
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(players, player)
        end
    end
    return players
end

-- ====== SILENT AIM - СТРЕЛЬБА ЧЕРЕЗ СТЕНЫ ======
local function getSilentAimTarget()
    if not LocalPlayer.Character then return nil end
    
    local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local closest = nil
    local closestDist = math.huge
    local fov = state.silentAim.fov
    local camera = Camera
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    
    for _, player in ipairs(getPlayers()) do
        if isTeamMate(player) then continue end
        if not isPlayerAlive(player) then continue end
        
        local targetPart = getTargetPart(player)
        if targetPart then
            local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
            
            if dist < fov and dist < closestDist then
                closest = player
                closestDist = dist
            end
        end
    end
    return closest
end

-- ====== ПЕРЕХВАТ ВЫСТРЕЛОВ ======
local function hookWeapon(tool)
    if not tool then return end
    if hookedWeapons[tool] then return end
    
    for _, child in ipairs(tool:GetChildren()) do
        if child:IsA("RemoteEvent") then
            local oldFire = child.FireServer
            
            child.FireServer = function(...)
                if state.enabled and state.silentAim.enabled then
                    local target = getSilentAimTarget()
                    if target and not isTeamMate(target) and isPlayerAlive(target) then
                        local targetPart = getTargetPart(target)
                        if targetPart then
                            local args = {...}
                            local targetPos = targetPart.Position
                            
                            for i, arg in ipairs(args) do
                                if type(arg) == "Vector3" then
                                    args[i] = targetPos
                                elseif type(arg) == "CFrame" then
                                    args[i] = CFrame.new(targetPos)
                                elseif type(arg) == "table" then
                                    if arg.Position then arg.Position = targetPos end
                                    if arg.p then arg.p = targetPos end
                                    if arg.target then arg.target = targetPos end
                                    if arg.origin then arg.origin = targetPos end
                                    if arg[1] and type(arg[1]) == "Vector3" then
                                        arg[1] = targetPos
                                    end
                                    if arg[2] and type(arg[2]) == "Vector3" then
                                        arg[2] = targetPos
                                    end
                                end
                            end
                            
                            return oldFire(unpack(args))
                        end
                    end
                end
                return oldFire(...)
            end
            
            hookedWeapons[tool] = true
        end
        
        if child:IsA("RemoteFunction") then
            local oldInvoke = child.InvokeServer
            
            child.InvokeServer = function(...)
                if state.enabled and state.silentAim.enabled then
                    local target = getSilentAimTarget()
                    if target and not isTeamMate(target) and isPlayerAlive(target) then
                        local targetPart = getTargetPart(target)
                        if targetPart then
                            local args = {...}
                            local targetPos = targetPart.Position
                            
                            for i, arg in ipairs(args) do
                                if type(arg) == "Vector3" then
                                    args[i] = targetPos
                                elseif type(arg) == "CFrame" then
                                    args[i] = CFrame.new(targetPos)
                                elseif type(arg) == "table" then
                                    if arg.Position then arg.Position = targetPos end
                                    if arg.p then arg.p = targetPos end
                                    if arg[1] and type(arg[1]) == "Vector3" then
                                        arg[1] = targetPos
                                    end
                                end
                            end
                            
                            return oldInvoke(unpack(args))
                        end
                    end
                end
                return oldInvoke(...)
            end
            
            hookedWeapons[tool] = true
        end
    end
end

-- ====== ПРОВЕРКА ОРУЖИЯ ======
local function checkWeapons()
    local character = LocalPlayer.Character
    if not character then return end
    
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            hookWeapon(tool)
        end
    end
end

-- ====== ESP ======
local function createESPObject(player)
    if not hasDrawing then return end
    
    local esp = {
        Box = Drawing.new("Square"),
        Name = Drawing.new("Text"),
        Health = Drawing.new("Text"),
        Skeleton = {},
        player = player,
        isDead = false,
    }
    
    esp.Box.Visible = false
    esp.Box.Thickness = 2
    esp.Box.Color = state.esp.color
    esp.Box.Filled = false
    
    esp.Name.Visible = false
    esp.Name.Color = Color3.fromRGB(255, 255, 255)
    esp.Name.Size = 16
    esp.Name.Center = true
    esp.Name.Outline = true
    esp.Name.OutlineColor = Color3.fromRGB(0, 0, 0)
    esp.Name.Font = 3
    
    esp.Health.Visible = false
    esp.Health.Color = Color3.fromRGB(200, 255, 200)
    esp.Health.Size = 13
    esp.Health.Outline = true
    esp.Health.OutlineColor = Color3.fromRGB(0, 0, 0)
    esp.Health.Font = 3
    
    espObjects[player] = esp
    return esp
end

local function getBonePositions(character)
    local bones = {}
    local skeletonJoints = {
        {"Head", "Torso"},
        {"Head", "Neck"},
        {"Neck", "UpperTorso"},
        {"UpperTorso", "LowerTorso"},
        {"LowerTorso", "HumanoidRootPart"},
        {"LeftShoulder", "LeftUpperArm"},
        {"LeftUpperArm", "LeftLowerArm"},
        {"LeftLowerArm", "LeftHand"},
        {"RightShoulder", "RightUpperArm"},
        {"RightUpperArm", "RightLowerArm"},
        {"RightLowerArm", "RightHand"},
        {"LeftHip", "LeftUpperLeg"},
        {"LeftUpperLeg", "LeftLowerLeg"},
        {"LeftLowerLeg", "LeftFoot"},
        {"RightHip", "RightUpperLeg"},
        {"RightUpperLeg", "RightLowerLeg"},
        {"RightLowerLeg", "RightFoot"},
    }
    
    for _, joint in ipairs(skeletonJoints) do
        local part1 = character:FindFirstChild(joint[1])
        local part2 = character:FindFirstChild(joint[2])
        if part1 and part2 then
            table.insert(bones, {part1.Position, part2.Position})
        end
    end
    return bones
end

local function updateESP()
    if not state.enabled or not state.esp.enabled or not hasDrawing then
        for _, esp in pairs(espObjects) do
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Health.Visible = false
            for _, bone in pairs(esp.Skeleton) do
                if bone then bone.Visible = false end
            end
        end
        return
    end
    
    local camera = Camera
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        
        local isDead = not isPlayerAlive(player)
        
        if isDead or isTeamMate(player) then
            if espObjects[player] then
                local esp = espObjects[player]
                esp.Box.Visible = false
                esp.Name.Visible = false
                esp.Health.Visible = false
                for _, bone in pairs(esp.Skeleton) do
                    if bone then bone.Visible = false end
                end
                esp.isDead = true
            end
            continue
        end
        
        local character = player.Character
        if not character then continue end
        
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then continue end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then continue end
        
        local distance = (rootPart.Position - camera.CFrame.Position).Magnitude
        if distance > state.esp.distance then continue end
        
        local esp = espObjects[player]
        if not esp then
            esp = createESPObject(player)
        end
        if not esp then continue end
        
        esp.isDead = false
        
        local screenPos, onScreen = camera:WorldToViewportPoint(rootPart.Position)
        if not onScreen then
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Health.Visible = false
            continue
        end
        
        local size = 4 / distance * 100
        local height = size * 2.5
        local width = size * 1.2
        
        local topLeft = Vector2.new(screenPos.X - width/2, screenPos.Y - height/2)
        local bottomRight = Vector2.new(screenPos.X + width/2, screenPos.Y + height/2)
        
        if state.esp.boxes then
            esp.Box.Visible = true
            esp.Box.Position = topLeft
            esp.Box.Size = Vector2.new(width, height)
            esp.Box.Color = state.esp.color
            esp.Box.Thickness = 2
        else
            esp.Box.Visible = false
        end
        
        if state.esp.names then
            esp.Name.Visible = true
            esp.Name.Position = Vector2.new(screenPos.X, topLeft.Y - 22)
            esp.Name.Text = player.Name
        else
            esp.Name.Visible = false
        end
        
        if state.esp.healthBar then
            esp.Health.Visible = true
            local healthPercent = humanoid.Health / humanoid.MaxHealth
            local healthColor = Color3.fromRGB(
                255 - (healthPercent * 255),
                healthPercent * 255,
                100
            )
            esp.Health.Color = healthColor
            esp.Health.Position = Vector2.new(screenPos.X, bottomRight.Y + 22)
            esp.Health.Text = string.format("%.0f%%", healthPercent * 100)
        else
            esp.Health.Visible = false
        end
        
        if state.esp.skeleton and not esp.isDead then
            local bones = getBonePositions(character)
            for i, bone in ipairs(bones) do
                local pos1, onScreen1 = camera:WorldToViewportPoint(bone[1])
                local pos2, onScreen2 = camera:WorldToViewportPoint(bone[2])
                
                if onScreen1 and onScreen2 then
                    if not esp.Skeleton[i] then
                        esp.Skeleton[i] = Drawing.new("Line")
                        esp.Skeleton[i].Thickness = 2
                        esp.Skeleton[i].Color = state.esp.color
                    end
                    esp.Skeleton[i].Visible = true
                    esp.Skeleton[i].From = Vector2.new(pos1.X, pos1.Y)
                    esp.Skeleton[i].To = Vector2.new(pos2.X, pos2.Y)
                    esp.Skeleton[i].Color = state.esp.color
                elseif esp.Skeleton[i] then
                    esp.Skeleton[i].Visible = false
                end
            end
        else
            for _, bone in pairs(esp.Skeleton) do
                if bone then bone.Visible = false end
            end
        end
    end
end

-- ====== АИМБОТ ======
local function findBestTarget(fov, checkVisible)
    if not LocalPlayer.Character then return nil end
    
    local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local closest = nil
    local closestDist = math.huge
    local camera = Camera
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    
    for _, player in ipairs(getPlayers()) do
        if isTeamMate(player) then continue end
        if not isPlayerAlive(player) then continue end
        
        local targetPart = getTargetPart(player)
        if targetPart then
            local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
            if checkVisible and not onScreen then continue end
            
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
            if dist < fov and dist < closestDist then
                closest = player
                closestDist = dist
            end
        end
    end
    return closest
end

local function aimbotLoop()
    if not state.enabled or not state.aimbot.enabled then return end
    
    local target = findBestTarget(state.aimbot.fov, state.aimbot.visibleCheck)
    if target then
        local targetPart = getTargetPart(target)
        if targetPart then
            local camera = Camera
            local targetPos = targetPart.Position
            local lookAt = CFrame.lookAt(camera.CFrame.Position, targetPos)
            camera.CFrame = camera.CFrame:Lerp(lookAt, state.aimbot.smoothness)
        end
    end
end

-- ====== ТЕЛЕПОРТ ======
local function teleportToPlayer(targetPlayer)
    if not LocalPlayer.Character or isTeamMate(targetPlayer) then return end
    if not isPlayerAlive(targetPlayer) then return end
    
    local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local targetRoot = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return end
    
    local direction
    local mode = state.teleport.mode
    
    if mode == "Front" then
        direction = (targetRoot.Position - rootPart.Position).Unit
    elseif mode == "Behind" then
        direction = (rootPart.Position - targetRoot.Position).Unit
    else
        direction = Vector3.new(math.random(-100, 100), 0, math.random(-100, 100)).Unit
    end
    
    local newPos = targetRoot.Position + direction * state.teleport.distance
    rootPart.CFrame = CFrame.new(newPos)
end

