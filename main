-- Загрузка конструктора Moonware
local Builder = loadstring(game:HttpGet("https://raw.githubusercontent.com/pidaraks1488/moonware/refs/heads/main/src/builder.lua"))()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")
local StarterGui = game:GetService("StarterGui")

-- Создание главного окна
local window = Builder.new({
    Title = "Super Script v2",
    ToggleKey = Enum.KeyCode.RightControl,
    Animation = "Default",
    TabAnimation = "Fade",
    TabAnimationEnabled = true,
    TabAnimationDuration = 0.18,
    Responsive = true,
    ResponsiveMargin = 16,
    MinScale = 0.58,
    MaxScale = 1,
    BlurSize = 0,
    BackdropTransparency = 0.68,
    Width = 600,
    Height = 440,
    SidebarWidth = 144,
    TabHeight = 38,
    TabGap = 8,
    Config = {
        Enabled = true,
        Folder = "SuperScript",
        File = "config.json",
    },
})

-- === СОСТОЯНИЯ ===
local state = {
    speedHack = false,
    walkSpeed = 50,
    aimBot = false,
    aimSmoothness = 0.3,
    aimFov = 200,
    isHackActive = false,
}

local player = Players.LocalPlayer
local character = player.Character
local humanoid = character and character:FindFirstChildOfClass("Humanoid")

-- === ФУНКЦИИ ДЛЯ АИМА ===
local function getClosestPlayer()
    local closest = nil
    local shortestDist = state.aimFov
    local mouse = player:GetMouse()
    local camera = workspace.CurrentCamera

    for _, target in ipairs(Players:GetPlayers()) do
        if target ~= player and target.Character and target.Character:FindFirstChild("Head") then
            local headPos = camera:WorldToViewportPoint(target.Character.Head.Position)
            if headPos then
                local distance = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(headPos.X, headPos.Y)).Magnitude
                if distance < shortestDist then
                    shortestDist = distance
                    closest = target
                end
            end
        end
    end
    return closest
end

-- === СПИДХАК ===
local function toggleSpeedHack(enabled)
    state.speedHack = enabled
    if not humanoid then return end
    if enabled then
        humanoid.WalkSpeed = state.walkSpeed
    else
        humanoid.WalkSpeed = 16
    end
end

-- === АИМ ===
RunService.RenderStepped:Connect(function()
    if not state.aimBot then return end
    local target = getClosestPlayer()
    if target and target.Character and target.Character:FindFirstChild("Head") then
        local head = target.Character.Head
        local camera = workspace.CurrentCamera
        local targetPos = head.Position + Vector3.new(0, 0.5, 0)

        local currentCF = camera.CFrame
        local lookAt = CFrame.lookAt(currentCF.Position, targetPos)
        local tweenInfo = TweenInfo.new(state.aimSmoothness, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(camera, tweenInfo, {CFrame = lookAt})
        tween:Play()
    end
end)

-- === ИСПРАВЛЕННАЯ ЭКСТРЕМАЛЬНАЯ КНОПКА ===
local function triggerExtremeHack()
    if state.isHackActive then return end
    state.isHackActive = true

    -- СОЗДАЕМ GUI НАПРЯМУЮ НА ЭКРАНЕ ИГРОКА
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "ExtremeHackGUI"
    screenGui.ResetOnSpawn = false -- Чтобы не исчезал при респавне
    screenGui.Parent = player.PlayerGui

    -- Главная надпись
    local textLabel = Instance.new("TextLabel")
    textLabel.Name = "IdiotText"
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = "You Are IDIOT"
    textLabel.TextColor3 = Color3.new(1, 0, 0)
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    textLabel.TextWrapped = true
    textLabel.Parent = screenGui

    -- Добавляем случайные маленькие надписи для эффекта
    for i = 1, 20 do
        local smallText = Instance.new("TextLabel")
        smallText.Size = UDim2.new(0, math.random(50, 200), 0, math.random(20, 50))
        smallText.Position = UDim2.new(math.random(), 0, math.random(), 0)
        smallText.BackgroundTransparency = 1
        smallText.Text = "YOU ARE IDIOT!"
        smallText.TextColor3 = Color3.new(math.random(), math.random(), math.random())
        smallText.TextScaled = true
        smallText.Font = Enum.Font.GothamBold
        smallText.TextStrokeTransparency = 0.5
        smallText.TextStrokeColor3 = Color3.new(0, 0, 0)
        smallText.Parent = screenGui
    end

    -- Функция мерцания
    local function flashText()
        for i = 1, 30 do
            textLabel.Visible = not textLabel.Visible
            task.wait(0.05)
        end
        textLabel.Visible = true
    end

    -- Воспроизведение музыки
    local soundId = "rbxassetid://107820249146754"
    local sound = Instance.new("Sound")
    sound.SoundId = soundId
    sound.Volume = 1
    sound.Looped = false
    sound.Parent = workspace
    sound:Play()

    -- Запуск мерцания
    flashText()

    -- Таймер 30 секунд
    task.wait(30)

    -- Закрытие Roblox
    game:Shutdown()
end

-- === ВКЛАДКИ ===
local mainTab = window:CreateTab("Main", "lucide-home")
local hackTab = window:CreateTab("Hacks", "lucide-zap")
local funTab = window:CreateTab("Fun", "lucide-smile")

-- Вкладка Main
local infoSection = mainTab:Section("Info")
infoSection:Paragraph("Welcome", "Используйте RightControl для открытия меню.")

-- Вкладка Hacks
local speedSection = hackTab:Section("Speed Hack")
speedSection:Toggle("Enable Speed", false, function(enabled)
    toggleSpeedHack(enabled)
end, 1)

speedSection:Slider("Walk Speed", 16, 250, 50, 1, function(value)
    state.walkSpeed = value
    if state.speedHack then
        toggleSpeedHack(true)
    end
end, 2)

local aimSection = hackTab:Section("Aim Bot")
aimSection:Toggle("Enable Aim", false, function(enabled)
    state.aimBot = enabled
end, 1)

aimSection:Slider("Smoothness", 0.1, 1, 0.3, 0.05, function(value)
    state.aimSmoothness = value
end, 2)

aimSection:Slider("FOV", 50, 400, 200, 10, function(value)
    state.aimFov = value
end, 3)

-- Вкладка Fun
local extremeSection = funTab:Section("Extreme Hack")
extremeSection:Paragraph("Warning", "Нажмите на кнопку, чтобы запустить эффект 'You Are IDIOT'!")
extremeSection:Button("Extreme HACK", function()
    triggerExtremeHack()
end, 1)

return window
