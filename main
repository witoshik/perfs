-- Загружаем библиотеку Moonware
local Builder = loadstring(game:HttpGet("https://raw.githubusercontent.com/pidaraks1488/moonware/refs/heads/main/src/builder.lua"))()

-- Создаем окно
local window = Builder.new({
    Title = "MM2 Enhanced",
    ToggleKey = Enum.KeyCode.RightControl,
    Width = 500,
    Height = 400,
})

-- Создаем вкладку
local mainTab = window:CreateTab("Main", "lucide-home")

-- Секция для функций
local functionsSection = mainTab:Section("Functions")

-- Состояния
local state = {
    wallhack = false,
    showRoles = true,
}

-- Переменная для хранения ESP объектов
local espObjects = {}
local playerRoles = {}

-- Функция для определения роли игрока
local function getPlayerRole(player)
    if not player or not player.Character then
        return "Unknown"
    end
    
    local character = player.Character
    local role = "Unknown"
    
    -- Проверка на Шерифа (Sheriff)
    if character:FindFirstChild("Sheriff") or character:FindFirstChild("SheriffHat") then
        role = "Sheriff"
    -- Проверка на Убийцу (Murderer)
    elseif character:FindFirstChild("Knife") or character:FindFirstChild("Murderer") then
        role = "Murderer"
    else
        -- Проверяем наличие оружия у игрока (обычный игрок)
        local hasGun = false
        for _, child in pairs(character:GetChildren()) do
            if child:IsA("Tool") and child.Name == "Gun" then
                hasGun = true
                break
            end
        end
        if hasGun then
            role = "Innocent" -- Обычный игрок с пистолетом
        else
            role = "Innocent"
        end
    end
    
    return role
end

-- Функция для обновления ESP и ролей
local function updateESP()
    -- Очищаем старые объекты ESP
    for _, obj in pairs(espObjects) do
        if obj and obj.Parent then
            obj:Destroy()
        end
    end
    espObjects = {}
    
    -- Очищаем старые роли
    for _, label in pairs(playerRoles) do
        if label and label.Parent then
            label:Destroy()
        end
    end
    playerRoles = {}
    
    if not state.wallhack and not state.showRoles then
        return
    end
    
    local players = game:GetService("Players")
    local localPlayer = players.LocalPlayer
    
    for _, player in pairs(players:GetPlayers()) do
        if player ~= localPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local character = player.Character
            local rootPart = character.HumanoidRootPart
            
            -- Wall Hack (показываем игроков сквозь стены)
            if state.wallhack then
                -- Создаем точку над игроком
                local espPoint = Instance.new("Part")
                espPoint.Name = "ESP_Point"
                espPoint.Size = Vector3.new(2, 2, 2)
                espPoint.Shape = Enum.PartType.Ball
                espPoint.Material = Enum.Material.Neon
                espPoint.Color = Color3.fromRGB(0, 255, 0)
                espPoint.Transparency = 0.3
                espPoint.Anchored = true
                espPoint.CanCollide = false
                espPoint.Parent = workspace
            
                -- Привязываем точку к игроку
                local weld = Instance.new("Weld")
                weld.Part0 = rootPart
                weld.Part1 = espPoint
                weld.C0 = CFrame.new(0, 4, 0)
                weld.Parent = espPoint
                
                table.insert(espObjects, espPoint)
                table.insert(espObjects, weld)
            end
            
            -- Показываем роли под игроком
            if state.showRoles then
                local role = getPlayerRole(player)
                local roleColor = Color3.fromRGB(255, 255, 255)
                
                if role == "Murderer" then
                    roleColor = Color3.fromRGB(255, 0, 0) -- Красный для убийцы
                elseif role == "Sheriff" then
                    roleColor = Color3.fromRGB(0, 0, 255) -- Синий для шерифа
                elseif role == "Innocent" then
                    roleColor = Color3.fromRGB(0, 255, 0) -- Зеленый для обычных
                end
                
                -- Создаем BillboardGui для отображения роли
                local billboard = Instance.new("BillboardGui")
                billboard.Name = "RoleDisplay"
                billboard.Size = UDim2.new(0, 200, 0, 50)
                billboard.AlwaysOnTop = true
                billboard.MaxDistance = 150
                billboard.Parent = rootPart
                
                local textLabel = Instance.new("TextLabel")
                textLabel.Name = "RoleText"
                textLabel.Size = UDim2.new(1, 0, 1, 0)
                textLabel.BackgroundTransparency = 1
                textLabel.Text = role
                textLabel.TextColor3 = roleColor
                textLabel.TextScaled = true
                textLabel.Font = Enum.Font.GothamBold
                textLabel.TextStrokeTransparency = 0.5
                textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                textLabel.Parent = billboard
                
                table.insert(playerRoles, billboard)
                table.insert(playerRoles, textLabel)
            end
        end
    end
end

-- Функция для очистки ESP
local function clearESP()
    for _, obj in pairs(espObjects) do
        if obj and obj.Parent then
            obj:Destroy()
        end
    end
    espObjects = {}
    
    for _, label in pairs(playerRoles) do
        if label and label.Parent then
            label:Destroy()
        end
    end
    playerRoles = {}
end

-- Включаем/выключаем Wall Hack
functionsSection:Toggle("Wall Hack", false, function(enabled)
    state.wallhack = enabled
    if enabled then
        updateESP()
    else
        clearESP()
        if state.showRoles then
            updateESP() -- Обновляем только роли
        end
    end
end, 1)

-- Включаем/выключаем отображение ролей
functionsSection:Toggle("Show Roles", true, function(enabled)
    state.showRoles = enabled
    if enabled then
        updateESP()
    else
        for _, label in pairs(playerRoles) do
            if label and label.Parent then
                label:Destroy()
            end
        end
        playerRoles = {}
    end
end, 2)

-- Кнопка обновления
functionsSection:Button("Refresh ESP", function()
    clearESP()
    updateESP()
end, 3)

-- Секция информации
local infoSection = mainTab:Section("Info")
infoSection:Paragraph("Help", "Wall Hack - показывает игроков сквозь стены\nShow Roles - отображает роли под игроками\n\nРоли: Murderer (красный), Sheriff (синий), Innocent (зеленый)", 1)

-- Автоматическое обновление ESP при появлении новых игроков
game:GetService("Players").PlayerAdded:Connect(function()
    task.wait(0.5)
    clearESP()
    updateESP()
end)

game:GetService("Players").PlayerRemoving:Connect(function()
    task.wait(0.1)
    clearESP()
    updateESP()
end)

-- Фоновый цикл обновления
task.spawn(function()
    while true do
        task.wait(2)
        if state.wallhack or state.showRoles then
            clearESP()
            updateESP()
        end
    end
end)

return window
