-- ====== ====== ====== ====== ====== ====== ====== ====== ======
-- ====== ЗАГРУЗОЧНЫЙ ЭКРАН (ПОЛНЫЙ ЭКРАН) ======
-- ====== ====== ====== ====== ====== ====== ====== ====== ======

local function createLoadingScreen()
    -- Создаём ScreenGui на весь экран
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "LoadingScreen"
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    screenGui.Parent = game:GetService("CoreGui")
    screenGui.ResetOnSpawn = false
    
    -- ЧЕРНЫЙ ФОН (полный экран - 100% размер)
    local background = Instance.new("Frame")
    background.Name = "Background"
    background.Size = UDim2.new(1, 0, 1, 0) -- ВЕСЬ ЭКРАН
    background.Position = UDim2.new(0, 0, 0, 0)
    background.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    background.BackgroundTransparency = 0
    background.Parent = screenGui
    
    -- ====== ЗВЕЗДЫ (100 штук) ======
    local stars = {}
    for i = 1, 100 do
        local star = Instance.new("Frame")
        star.Name = "Star_" .. i
        local size = math.random(1, 4)
        star.Size = UDim2.new(0, size, 0, size)
        star.Position = UDim2.new(math.random(), 0, math.random(), 0)
        star.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        star.BackgroundTransparency = math.random(20, 70) / 100
        star.BorderSizePixel = 0
        star.Parent = screenGui
        
        -- Свечение для звезд
        local glow = Instance.new("Frame")
        glow.Name = "Glow_" .. i
        glow.Size = UDim2.new(0, size * 4, 0, size * 4)
        glow.Position = UDim2.new(0.5, -size * 2, 0.5, -size * 2)
        glow.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        glow.BackgroundTransparency = 0.92
        glow.BorderSizePixel = 0
        glow.Parent = star
        
        stars[i] = {
            frame = star,
            glow = glow,
            speed = 0.0003 + math.random() * 0.0015,
            direction = math.random() * 2 * math.pi,
            size = size,
            twinkleSpeed = 0.5 + math.random() * 2,
            twinkleOffset = math.random() * 6,
        }
    end
    
    -- ====== ТЕКСТ "Leek Cheats" ======
    local textContainer = Instance.new("Frame")
    textContainer.Name = "TextContainer"
    textContainer.Size = UDim2.new(0, 900, 0, 150)
    textContainer.Position = UDim2.new(0.5, -450, 0.4, -75)
    textContainer.BackgroundTransparency = 1
    textContainer.Parent = screenGui
    
    local letters = {}
    local text = "Leek Cheats"
    local letterWidth = 900 / #text
    local letterSize = 90
    
    for i = 1, #text do
        local char = text:sub(i, i)
        
        -- Основная буква
        local letter = Instance.new("TextLabel")
        letter.Name = "Letter_" .. i
        letter.Size = UDim2.new(0, letterWidth, 0, letterSize)
        letter.Position = UDim2.new((i-1) / #text, 0, 0.5, -letterSize/2)
        letter.BackgroundTransparency = 1
        letter.Text = char
        letter.TextColor3 = Color3.fromRGB(255, 255, 255)
        letter.TextSize = letterSize
        letter.Font = Enum.Font.GothamBold
        letter.TextXAlignment = Enum.TextXAlignment.Center
        letter.TextYAlignment = Enum.TextYAlignment.Center
        letter.TextStrokeColor3 = Color3.fromRGB(200, 200, 255)
        letter.TextStrokeTransparency = 0.1
        letter.TextTransparency = 1
        letter.Parent = textContainer
        
        -- Неоновое свечение буквы
        local glow = Instance.new("Frame")
        glow.Name = "Glow_" .. i
        glow.Size = UDim2.new(0, letterWidth + 40, 0, letterSize + 40)
        glow.Position = UDim2.new((i-1) / #text, -20, 0.5, -letterSize/2 - 20)
        glow.BackgroundColor3 = Color3.fromRGB(200, 200, 255)
        glow.BackgroundTransparency = 0.95
        glow.BorderSizePixel = 0
        glow.Parent = textContainer
        
        -- Тень буквы
        local shadow = Instance.new("TextLabel")
        shadow.Name = "Shadow_" .. i
        shadow.Size = UDim2.new(0, letterWidth, 0, letterSize)
        shadow.Position = UDim2.new((i-1) / #text, 3, 0.5, -letterSize/2 + 3)
        shadow.BackgroundTransparency = 1
        shadow.Text = char
        shadow.TextColor3 = Color3.fromRGB(100, 100, 150)
        shadow.TextSize = letterSize
        shadow.Font = Enum.Font.GothamBold
        shadow.TextXAlignment = Enum.TextXAlignment.Center
        shadow.TextYAlignment = Enum.TextYAlignment.Center
        shadow.TextTransparency = 1
        shadow.Parent = textContainer
        
        letters[i] = {letter = letter, shadow = shadow, glow = glow}
    end
    
    -- ====== ПОДПИСЬ "by Witoshi" ======
    local subtitle = Instance.new("TextLabel")
    subtitle.Name = "Subtitle"
    subtitle.Size = UDim2.new(0, 500, 0, 50)
    subtitle.Position = UDim2.new(0.5, -250, 0.55, 0)
    subtitle.BackgroundTransparency = 1
    subtitle.Text = "by Witoshi"
    subtitle.TextColor3 = Color3.fromRGB(180, 180, 200)
    subtitle.TextSize = 28
    subtitle.Font = Enum.Font.Gotham
    subtitle.TextXAlignment = Enum.TextXAlignment.Center
    subtitle.TextYAlignment = Enum.TextYAlignment.Center
    subtitle.TextTransparency = 1
    subtitle.Parent = screenGui
    
    -- ====== ПОЛОСА ЗАГРУЗКИ ======
    local loadingBarBg = Instance.new("Frame")
    loadingBarBg.Name = "LoadingBarBg"
    loadingBarBg.Size = UDim2.new(0.4, 0, 0, 4)
    loadingBarBg.Position = UDim2.new(0.3, 0, 0.68, 0)
    loadingBarBg.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    loadingBarBg.BackgroundTransparency = 0.5
    loadingBarBg.BorderSizePixel = 1
    loadingBarBg.BorderColor3 = Color3.fromRGB(80, 80, 120)
    loadingBarBg.Parent = screenGui
    
    local loadingBar = Instance.new("Frame")
    loadingBar.Name = "LoadingBar"
    loadingBar.Size = UDim2.new(0, 0, 1, 0)
    loadingBar.Position = UDim2.new(0, 0, 0, 0)
    loadingBar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    loadingBar.BackgroundTransparency = 0.2
    loadingBar.BorderSizePixel = 0
    loadingBar.Parent = loadingBarBg
    
    -- Свечение полосы
    local loadingGlow = Instance.new("Frame")
    loadingGlow.Name = "LoadingGlow"
    loadingGlow.Size = UDim2.new(0, 0, 1, 10)
    loadingGlow.Position = UDim2.new(0, 0, 0, -3)
    loadingGlow.BackgroundColor3 = Color3.fromRGB(200, 200, 255)
    loadingGlow.BackgroundTransparency = 0.7
    loadingGlow.BorderSizePixel = 0
    loadingGlow.Parent = loadingBar
    
    -- ====== ПРОЦЕНТЫ ======
    local percentLabel = Instance.new("TextLabel")
    percentLabel.Name = "PercentLabel"
    percentLabel.Size = UDim2.new(1, 0, 0, 30)
    percentLabel.Position = UDim2.new(0, 0, 0.73, 0)
    percentLabel.BackgroundTransparency = 1
    percentLabel.Text = "0%"
    percentLabel.TextColor3 = Color3.fromRGB(150, 150, 180)
    percentLabel.TextSize = 16
    percentLabel.Font = Enum.Font.Gotham
    percentLabel.TextXAlignment = Enum.TextXAlignment.Center
    percentLabel.TextYAlignment = Enum.TextYAlignment.Center
    percentLabel.Parent = screenGui
    
    return screenGui, letters, subtitle, loadingBar, loadingGlow, percentLabel, stars
end

-- ====== АНИМАЦИЯ ЗВЕЗД ======
local function animateStars(stars)
    task.spawn(function()
        while true do
            for _, s in ipairs(stars) do
                if s.frame and s.frame.Parent then
                    -- Движение звезд
                    local x = s.frame.Position.X.Scale + s.speed * math.cos(s.direction)
                    local y = s.frame.Position.Y.Scale + s.speed * math.sin(s.direction)
                    if x > 1 then x = 0 end
                    if x < 0 then x = 1 end
                    if y > 1 then y = 0 end
                    if y < 0 then y = 1 end
                    s.frame.Position = UDim2.new(x, 0, y, 0)
                    
                    -- Мерцание звезд
                    local twinkle = math.sin(tick() * s.twinkleSpeed + s.twinkleOffset)
                    local transparency = 0.2 + (twinkle + 1) / 2 * 0.6
                    s.frame.BackgroundTransparency = transparency
                    s.glow.BackgroundTransparency = 0.85 + (twinkle + 1) / 2 * 0.12
                    
                    -- Размер звезд (пульсация)
                    local pulse = 1 + (twinkle + 1) / 2 * 0.5
                    s.frame.Size = UDim2.new(0, s.size * pulse, 0, s.size * pulse)
                    s.glow.Size = UDim2.new(0, s.size * 4 * pulse, 0, s.size * 4 * pulse)
                end
            end
            task.wait(0.02)
        end
    end)
end

-- ====== АНИМАЦИЯ ПОЯВЛЕНИЯ БУКВ (УСКОРЕННАЯ) ======
local function animateLetters(letters, speed, callback)
    local index = 1
    local function showNextLetter()
        if index <= #letters then
            local l = letters[index]
            local transparency = 1
            local function fadeIn()
                if transparency > 0 then
                    transparency = transparency - 0.06 -- БЫСТРЕЕ (было 0.03)
                    l.letter.TextTransparency = transparency
                    l.shadow.TextTransparency = transparency
                    l.glow.BackgroundTransparency = 0.95 + (1 - transparency) * 0.85
                    task.wait(0.01) -- БЫСТРЕЕ (было 0.015)
                    fadeIn()
                else
                    l.glow.BackgroundTransparency = 0.2
                    task.wait(0.03) -- БЫСТРЕЕ (было 0.05)
                    l.glow.BackgroundTransparency = 0.95
                end
            end
            fadeIn()
            index = index + 1
            task.wait(speed) -- 0.05 сек между буквами (было 0.08)
            showNextLetter()
        else
            if callback then callback() end
        end
    end
    showNextLetter()
end

-- ====== ЗАПУСК ЗАГРУЗОЧНОГО ЭКРАНА ======
local screenGui, letters, subtitle, loadingBar, loadingGlow, percentLabel, stars = createLoadingScreen()

-- Запускаем анимацию звезд
animateStars(stars)

-- ====== АНИМАЦИЯ ЗАГРУЗКИ ======
local loadingProgress = 0
local loadingSpeed = 0.02
local isLoadingComplete = false

local function updateLoading()
    if isLoadingComplete then return end
    loadingProgress = loadingProgress + 1
    if loadingProgress <= 100 then
        local parentWidth = loadingBar.Parent.Size.X.Offset
        local barWidth = (loadingProgress / 100) * parentWidth
        loadingBar.Size = UDim2.new(0, barWidth, 1, 0)
        loadingGlow.Size = UDim2.new(0, barWidth + 30, 1, 10)
        loadingGlow.Position = UDim2.new(0, -15, 0, -3)
        
        local brightness = math.floor(150 + (loadingProgress / 100) * 105)
        loadingBar.BackgroundColor3 = Color3.fromRGB(brightness, brightness, brightness)
        loadingGlow.BackgroundColor3 = Color3.fromRGB(brightness, brightness, brightness)
        
        percentLabel.Text = loadingProgress .. "%"
        
        task.wait(loadingSpeed)
        updateLoading()
    else
        isLoadingComplete = true
    end
end

-- ====== ЗАПУСК АНИМАЦИЙ ======
-- Буквы появляются быстрее (0.05 сек между буквами)
animateLetters(letters, 0.05, function()
    task.wait(0.15) -- Меньше паузы (было 0.2)
    
    -- Плавное появление подписи
    local function fadeInSubtitle()
        local transparency = subtitle.TextTransparency
        if transparency > 0 then
            subtitle.TextTransparency = transparency - 0.04 -- БЫСТРЕЕ (было 0.03)
            task.wait(0.015) -- БЫСТРЕЕ (было 0.02)
            fadeInSubtitle()
        end
    end
    fadeInSubtitle()
    
    task.wait(0.2) -- Меньше паузы (было 0.3)
    updateLoading()
end)

-- ====== УДАЛЕНИЕ ЗАГРУЗОЧНОГО ЭКРАНА ======
local function fadeOutLoadingScreen()
    if isLoadingComplete then
        local function fadeOut()
            if not screenGui or not screenGui.Parent then return end
            
            local transparency = 0
            local function step()
                transparency = transparency + 0.025
                if transparency < 1 then
                    for _, child in ipairs(screenGui:GetChildren()) do
                        if child:IsA("TextLabel") then
                            child.TextTransparency = math.min(child.TextTransparency + 0.025, 1)
                        end
                        if child:IsA("Frame") and child.Name ~= "Background" then
                            child.BackgroundTransparency = math.min(child.BackgroundTransparency + 0.025, 1)
                        end
                        if child:IsA("Frame") and child.Name:find("Star") then
                            child.BackgroundTransparency = math.min(child.BackgroundTransparency + 0.025, 1)
                        end
                    end
                    task.wait(0.015)
                    step()
                else
                    screenGui:Destroy()
                end
            end
            step()
        end
        
        task.wait(0.3) -- Меньше паузы (было 0.5)
        fadeOut()
    else
        task.wait(0.05)
        fadeOutLoadingScreen()
    end
end

-- Запускаем удаление
task.spawn(function()
    while not isLoadingComplete do
        task.wait(0.05)
    end
    fadeOutLoadingScreen()
end)

