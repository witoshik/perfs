-- Состояние скрипта
local state = {
    enabled = false,
    mouseUnlock = false,
    -- Настройки биндов
    binds = {
        toggleMenu = Enum.KeyCode.Home,
        unlockMouse = Enum.KeyCode.F1,
        disableAll = Enum.KeyCode.F8,
    },
