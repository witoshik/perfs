-- ====== АНИМАЦИЯ ПЕЧАТИ ТЕКСТА ======
local function typeText(label, shadow, text, speed, callback)
    local currentText = ""
    local index = 1
    local function typeChar()
        if index <= #text then
            currentText = currentText .. text:sub(index, index)
            label.Text = currentText
            if shadow then shadow.Text = currentText end
            index = index + 1
            task.wait(speed)
            return typeChar()
        else
            if callback then callback() end
        end
    end
    typeChar()
end

-- ====== ПЛАВНОЕ ПОЯВЛЕНИЕ ПОДПИСИ ======
local function fadeInSubtitle(subtitleLabel, subtitleShadow)
    local transparency = 1
    local function step()
        if transparency > 0 then
            transparency = transparency - 0.03
            subtitleLabel.TextTransparency = transparency
            subtitleShadow.TextTransparency = transparency
            task.wait(0.02)
            step()
        end
    end
    step()
end

-- ====== ЗАПУСК ЗАГРУЗОЧНОГО ЭКРАНА ======
local screenGui, titleLabel, titleShadow, subtitleLabel, subtitleShadow, loadingBar, loadingBarGlow, percentLabel = createLoadingScreen()

-- Анимация загрузки
local loadingProgress = 0
local loadingSpeed = 0.015
local isLoadingComplete = false

local function updateLoading()
    if isLoadingComplete then return end
    loadingProgress = loadingProgress + 1
    if loadingProgress <= 100 then
        -- Обновляем полосу загрузки
        local parentWidth = loadingBar.Parent.Size.X.Offset
        local barWidth = (loadingProgress / 100) * parentWidth
        loadingBar.Size = UDim2.new(0, barWidth, 1, 0)
        loadingBarGlow.Size = UDim2.new(0, barWidth + 20, 1, 4)
        loadingBarGlow.Position = UDim2.new(0, -10, 0, -2)
        
        -- Меняем цвет полосы (неоновый градиент)
        local r = math.floor(150 + (loadingProgress / 100) * 105)
        local g = math.floor(100 + (loadingProgress / 100) * 155)
        local b = 255
        loadingBar.BackgroundColor3 = Color3.fromRGB(r, g, b)
        loadingBarGlow.BackgroundColor3 = Color3.fromRGB(r, g, b)
        
        -- Обновляем проценты
        percentLabel.Text = loadingProgress .. "%"
        
        task.wait(loadingSpeed)
        updateLoading()
    else
        isLoadingComplete = true
    end
end

-- ====== ЗАПУСК АНИМАЦИЙ ======
-- Печатаем "Leek Cheats"
typeText(titleLabel, titleShadow, "Leek Cheats", 0.07, function()
    -- После завершения печати, показываем подпись и запускаем загрузку
    task.wait(0.2)
    
    -- Плавное появление подписи "by Witoshik"
    subtitleLabel.TextTransparency = 1
    subtitleShadow.TextTransparency = 1
    fadeInSubtitle(subtitleLabel, subtitleShadow)
    
    -- Запускаем полосу загрузки
    task.wait(0.3)
    updateLoading()
end)

-- ====== УДАЛЕНИЕ ЗАГРУЗОЧНОГО ЭКРАНА ======
local function fadeOutLoadingScreen()
    if isLoadingComplete then
        local function fadeOut()
            if not screenGui or not screenGui.Parent then return end
            
            local transparency = 0
            local function step()
                transparency = transparency + 0.03
                if transparency < 1 then
                    for _, child in ipairs(screenGui:GetChildren()) do
                        if child:IsA("TextLabel") then
                            child.TextTransparency = transparency
                        end
                        if child:IsA("Frame") and child.Name ~= "Background" then
                            child.BackgroundTransparency = math.min(child.BackgroundTransparency + 0.03, 1)
                        end
                    end
                    task.wait(0.02)
                    step()
                else
                    screenGui:Destroy()
                end
            end
            step()
        end
        
        task.wait(0.5)
        fadeOut()
    else
        task.wait(0.1)
        fadeOutLoadingScreen()
    end
end

-- Запускаем удаление в отдельном потоке
task.spawn(function()
    while not isLoadingComplete do
        task.wait(0.1)
    end
    fadeOutLoadingScreen()
end)

