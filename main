            for _, bone in pairs(esp.Skeleton) do
                if bone then bone.Visible = false end
            end
        end
    end
end, 4)

espSection:Toggle("Health Bar", state.esp.healthBar, function(val)
    state.esp.healthBar = val
end, 5)

espSection:Slider("Distance", 50, 5000, state.esp.distance, 5, function(val)
    state.esp.distance = val
end, 6)

espSection:ColorPicker("ESP Color", state.esp.color, function(color)
    state.esp.color = color
    for _, esp in pairs(espObjects) do
        esp.Box.Color = color
        for _, bone in pairs(esp.Skeleton) do
            if bone then bone.Color = color end
        end
    end
end, 7)

-- Вкладка НАСТРОЕК
local settingsSection = settingsTab:Section("UI Settings")
settingsSection:Paragraph("Info", "Customize menu appearance and controls", 0)

settingsSection:Slider("Menu Transparency", 0, 1, state.transparency, 0.05, function(val)
    state.transparency = val
    updateTransparency()
    print("[Settings] Transparency:", val)
end, 1)

settingsSection:Slider("Blur Size", 0, 24, state.blurSize, 1, function(val)
    state.blurSize = val
    window.BlurSize = val
    print("[Settings] Blur size:", val)
end, 2)

settingsSection:Keybind("Toggle Menu Key", state.binds.toggleMenu, function(key)
    if key then
        state.binds.toggleMenu = key
        window.ToggleKey = key
        print("[Settings] Menu key changed to:", key.Name)
    end
end, 3)

settingsSection:Keybind("Unlock Mouse Key", state.binds.unlockMouse, function(key)
    if key then
        state.binds.unlockMouse = key
        print("[Settings] Unlock mouse key changed to:", key.Name)
    end
end, 4)

settingsSection:Keybind("Disable All Key", state.binds.disableAll, function(key)
    if key then
        state.binds.disableAll = key
        print("[Settings] Disable all key changed to:", key.Name)
    end
end, 5)

settingsSection:Paragraph("Current Binds", 
    "Menu: " .. tostring(state.binds.toggleMenu.Name) .. "\n" ..
    "Unlock Mouse: " .. tostring(state.binds.unlockMouse.Name) .. "\n" ..
    "Disable All: " .. tostring(state.binds.disableAll.Name), 6)

-- ====== ОБРАБОТКА КЛАВИШ ======
mainMaid:Give(UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == state.binds.unlockMouse then
        state.mouseUnlock = not state.mouseUnlock
        toggleMouseUnlock(state.mouseUnlock)
        print("[Mouse] Toggled:", state.mouseUnlock and "UNLOCKED" or "LOCKED")
    end
    
    if state.enabled and state.teleport.enabled and input.KeyCode == state.teleport.key then
        local target = findBestTarget(500, false)
        if target and not isTeamMate(target) then
            teleportToPlayer(target)
            print("[Teleport] Teleported to", target.Name)
        else
            print("[Teleport] No valid target found")
        end
    end
    
    if input.KeyCode == state.binds.disableAll then
        print("[DISABLE] Disabling ALL features...")
        
        state.enabled = false
        state.aimbot.enabled = false
        if mainMaid._aimbotTask then
            mainMaid._aimbotTask:Disconnect()
            mainMaid._aimbotTask = nil
        end
        
        state.aimbot.silentAim = false
        if mainMaid._silentTask then
            mainMaid._silentTask:Disconnect()
            mainMaid._silentTask = nil
        end
        silentTarget = nil
        if fovCircle then fovCircle.Visible = false end
        
        state.esp.enabled = false
        if mainMaid._espTask then
            mainMaid._espTask:Disconnect()
            mainMaid._espTask = nil
        end
        for _, esp in pairs(espObjects) do
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Health.Visible = false
            for _, bone in pairs(esp.Skeleton) do
                if bone then bone.Visible = false end
            end
        end
        
        state.teleport.enabled = false
        
        if state.mouseUnlock then
            state.mouseUnlock = false
            toggleMouseUnlock(false)
        end
        
        print("[DISABLE] ALL features disabled!")
    end
end))

-- ====== ОТСЛЕЖИВАНИЕ ======
mainMaid:Give(Players.PlayerAdded:Connect(function(player)
    if state.esp.enabled then
        task.wait(0.5)
        createESPObject(player)
    end
end))

mainMaid:Give(LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if state.aimbot.silentAim then
        checkWeapons()
    end
end))

mainMaid:Give(RunService.RenderStepped:Connect(function()
    if state.enabled and state.aimbot.silentAim then
        checkWeapons()
        updateFovCircle()
    end
end))

-- ====== КОНФИГИ ======
window:CreateConfigSection(mainTab, "Configs")

-- ====== ОЧИСТКА ======
window:OnDestroy(function()
    toggleMouseUnlock(false)
    if fovCircle then
        fovCircle:Remove()
        fovCircle = nil
    end
    for _, esp in pairs(espObjects) do
        if esp.Box then esp.Box:Remove() end
        if esp.Name then esp.Name
return window
